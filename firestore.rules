rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar si el usuario es el dueño del documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Regla para colecciones que tienen un campo 'userId'
    match /{collectionName}/{docId} {
      // Permitir crear si el userId del nuevo documento coincide con el del usuario autenticado
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Permitir leer, actualizar o borrar si el userId del documento existente coincide
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
