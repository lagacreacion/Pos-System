rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar si el usuario es el dueño del documento
    function isOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Función para verificar si el nuevo documento pertenece al usuario
    function isCreator() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Reglas para todas las colecciones del POS con campo 'userId'
    match /products/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isCreator();
      allow update, delete: if isOwner();
    }

    match /customers/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isCreator();
      allow update, delete: if isOwner();
    }

    match /sales/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isCreator();
      allow update, delete: if isOwner();
    }

    match /debts/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isCreator();
      allow update, delete: if isOwner();
    }

    match /payments/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isCreator();
      allow update, delete: if isOwner();
    }

    match /promotions/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isCreator();
      allow update, delete: if isOwner();
    }
  }
}
